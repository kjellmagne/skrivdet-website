{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MeetingTemplate",
  "type": "object",
  "additionalProperties": false,
  "required": ["identity", "context", "perspective", "structure", "content_rules", "llm_prompting"],
  "properties": {
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "category", "language", "version"],
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "title": { "type": "string", "minLength": 1, "maxLength": 80 },
        "icon": { "type": "string", "description": "SF Symbol name" },
        "short_description": { "type": "string", "maxLength": 200 },
        "category": { "type": "string", "description": "Free-text template category. Unknown imported categories are allowed." },
        "tags": { "type": "array", "items": { "type": "string" } },
        "language": { "type": "string", "enum": ["nb-NO", "nn-NO", "en-US"] },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose"],
      "properties": {
        "purpose": { "type": "string" },
        "typical_setting": { "type": "string" },
        "typical_participants": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["role"],
            "properties": {
              "role": { "type": "string" },
              "name": { "type": "string" }
            }
          }
        },
        "goals": { "type": "array", "items": { "type": "string" } },
        "related_processes": { "type": "array", "items": { "type": "string" } }
      }
    },
    "perspective": {
      "type": "object",
      "additionalProperties": false,
      "required": ["voice", "audience", "tone"],
      "properties": {
        "voice": {
          "type": "string",
          "enum": ["first_person_singular", "first_person_plural", "third_person", "dual"]
        },
        "audience": {
          "type": "string",
          "enum": ["self", "colleagues", "hr", "bruker", "arkiv", "ledelse", "blandet"]
        },
        "tone": {
          "type": "string",
          "enum": ["formell", "semi_formell", "samtalepreget"]
        },
        "style_rules": { "type": "array", "items": { "type": "string" } },
        "preserve_original_voice": { "type": "boolean", "default": false }
      }
    },
    "structure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sections"],
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["title", "purpose", "format", "required"],
            "properties": {
              "title": { "type": "string" },
              "purpose": { "type": "string" },
              "format": {
                "type": "string",
                "enum": ["prose", "bullet_list", "numbered_list", "table", "fill_in", "quote_block"]
              },
              "required": { "type": "boolean" },
              "extraction_hints": { "type": "array", "items": { "type": "string" } }
            }
          }
        }
      }
    },
    "content_rules": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "required_elements": { "type": "array", "items": { "type": "string" } },
        "exclusions": { "type": "array", "items": { "type": "string" } },
        "uncertainty_handling": { "type": "string" },
        "action_item_format": { "type": "string" },
        "decision_marker": { "type": "string" },
        "speaker_attribution": {
          "type": "string",
          "enum": ["full_name", "role_only", "initials", "anonymized", "none"]
        }
      }
    },
    "llm_prompting": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "system_prompt_additions": { "type": "string" },
        "fallback_behavior": { "type": "string" },
        "post_processing": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "extract_action_items": { "type": "boolean", "default": false },
            "structured_output": {
              "type": "object",
              "description": "Optional JSON schema fragment for structured side-output"
            }
          }
        }
      }
    }
  }
}
